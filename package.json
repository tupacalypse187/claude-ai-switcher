{
  "name": "claude-ai-switcher",
  "version": "1.1.1",
  "description": "Switch between AI providers (Anthropic, GLM, Alibaba Qwen, OpenRouter, Ollama, Gemini) for Claude Code and OpenCode",
  "main": "dist/index.js",
  "bin": {
    "claude-switch": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc && npm run copy-hooks",
    "copy-hooks": "node -e \"const fs=require('fs-extra');fs.ensureDirSync('dist/hooks');fs.copySync('src/hooks','dist/hooks',{filter:f=>f.endsWith('.js')||!f.includes('.')});\"",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "clean": "rimraf dist"
  },
  "keywords": [
    "claude",
    "ai",
    "qwen",
    "glm",
    "anthropic",
    "alibaba",
    "opencode",
    "openrouter",
    "ollama",
    "gemini",
    "litellm"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "commander": "^11.1.0",
    "fs-extra": "^11.2.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/fs-extra": "^11.0.4",
    "rimraf": "^5.0.0",
    "typescript": "^5.3.0",
    "ts-node": "^10.9.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
